/* pages/index/index.wxss */

.container {
  padding: 24rpx 32rpx;
  padding-bottom: 200rpx;
  background-color: var(--surface);
  min-height: 100vh;
}

/* ========== 顶部栏 ========== */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
}

.top-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.top-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.top-right {
  position: relative;
  padding: 8rpx;
}

.dot {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 14rpx;
  height: 14rpx;
  background-color: #e53935;
  border-radius: 50%;
}

/* ========== 年月 + 周数 ========== */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.year-month {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--on_surface);
}

.week-badge {
  background-color: var(--surface-container-lowest);
  padding: 8rpx 24rpx;
  border-radius: 9999rpx;
  border: 2rpx solid var(--primary);
}

.week-badge text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary);
}

/* ========== 周日历 ========== */
.week-calendar {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  flex: 1;
}

.week-day-name {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--on_surface_variant);
  text-transform: uppercase;
}

.week-day-num-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.week-day-num {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--on_surface);
}

.week-day.selected .week-day-num-wrap {
  background-color: var(--primary);
}

.week-day.selected .week-day-num {
  color: #ffffff;
}

.week-day.today:not(.selected) .week-day-num-wrap {
  border: 3rpx solid var(--primary);
}

.week-day:active {
  opacity: 0.7;
}

/* ========== 空态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  gap: 16rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--on_surface);
  margin-top: 16rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--on_surface_variant);
  text-align: center;
}

/* ========== 药品列表 ========== */
.med-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ========== 药品卡片 ========== */
.med-card {
  background-color: var(--surface-container-lowest);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-primary);
}

.med-card:active {
  transform: scale(0.98);
  transition: transform 0.15s ease;
}

.med-card.taken {
  opacity: 0.75;
}

.med-card.urgent {
  border-left: 6rpx solid #e53935;
}

.med-card-body {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 20rpx;
}

/* 药品信息 */
.med-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.med-time {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.med-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--on_surface);
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.med-name.name-taken {
  color: #006e28;
}

.med-desc {
  font-size: 24rpx;
  color: var(--on_surface_variant);
  margin-bottom: 16rpx;
}

/* 进度条行 */
.med-usage {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.med-usage-label {
  font-size: 22rpx;
  color: var(--on_surface_variant);
  flex-shrink: 0;
}

.med-progress-track {
  flex: 1;
  height: 10rpx;
  background-color: var(--surface-container);
  border-radius: 5rpx;
  overflow: hidden;
}

.med-progress-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.med-usage-pct {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary);
  flex-shrink: 0;
  min-width: 60rpx;
  text-align: right;
}

/* ========== 打卡操作按钮 ========== */
.med-action {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 4rpx;
}

.action-btn {
  min-width: 108rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-checkin {
  background-color: var(--primary);
  box-shadow: 0 4rpx 16rpx rgba(0, 88, 188, 0.3);
}

.action-checkin:active {
  transform: scale(0.92);
}

.action-done {
  background-color: #006e28;
  box-shadow: 0 4rpx 16rpx rgba(0, 110, 40, 0.25);
}

.action-pending {
  background-color: var(--surface-container);
}

.action-btn-text {
  font-size: 24rpx;
  font-weight: 600;
}

.action-checkin .action-btn-text {
  color: #ffffff;
}

.action-done .action-btn-text {
  color: #ffffff;
}

.action-pending .action-btn-text {
  color: #8e8e93;
}

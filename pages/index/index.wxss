/* pages/index/index.wxss */

.container {
  padding: 32rpx;
  padding-bottom: 120rpx;
  background-color: var(--surface);
  min-height: 100vh;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.date-info {
  display: flex;
  flex-direction: column;
}

.date {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--on_surface);
  line-height: 1.2;
}

.weekday {
  font-size: 28rpx;
  color: var(--on_surface_variant);
  margin-top: 8rpx;
}

.streak-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #ffe0e0 100%);
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  color: #e53935;
  font-weight: 500;
}

/* Progress Card */
.progress-card {
  background: linear-gradient(135deg, #0058bc 0%, #0070eb 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 88, 188, 0.2);
}

.progress-info {
  display: flex;
  flex-direction: column;
}

.progress-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.progress-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #ffffff;
}

/* Progress Ring */
.progress-ring {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-bg,
.ring-fill {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.ring-bg {
  background: conic-gradient(
    rgba(255, 255, 255, 0.2) 0deg,
    rgba(255, 255, 255, 0.2) 360deg
  );
}

.ring-fill {
  background: conic-gradient(
    #ffffff 0deg,
    #ffffff calc(var(--progress) * 3.6deg),
    transparent calc(var(--progress) * 3.6deg)
  );
  mask: radial-gradient(transparent 55%, black 56%);
  -webkit-mask: radial-gradient(transparent 55%, black 56%);
}

.ring-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.percentage {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* Medication Section */
.medication-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--on_surface);
}

.view-all {
  font-size: 26rpx;
  color: var(--primary);
}

/* Medication List */
.medication-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.medication-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: var(--surface-container-lowest);
  border-radius: 16rpx;
  transition: transform 0.2s ease;
}

.medication-item:active {
  transform: scale(0.98);
}

.medication-item.taken {
  opacity: 0.7;
}

.medication-item.urgent {
  border-left: 6rpx solid #e53935;
}

.medication-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.medication-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.medication-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--on_surface);
  margin-bottom: 8rpx;
}

.medication-dosage {
  font-size: 24rpx;
  color: var(--on_surface_variant);
}

.medication-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.medication-time {
  font-size: 24rpx;
  color: var(--on_surface_variant);
}

.check-status {
  width: 40rpx;
  height: 40rpx;
}

/* Quick Actions */
.quick-actions {
  position: fixed;
  bottom: 160rpx;
  left: 50%;
  transform: translateX(-50%);
}

.btn-add {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-container) 100%);
  color: #ffffff;
  border: none;
  border-radius: 9999rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(0, 110, 40, 0.3);
}

.btn-add:active {
  transform: scale(0.98);
}

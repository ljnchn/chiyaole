<!--index.wxml-->
<view class="container">
  <!-- 年月 + 周数 -->
  <view class="calendar-header">
    <text class="year-month">{{yearMonth}}</text>
    <view class="week-badge">
      <text>第 {{weekNumber}} 周</text>
    </view>
  </view>

  <!-- 周日历 -->
  <view class="week-calendar">
    <view
      wx:for="{{weekDays}}"
      wx:key="date"
      class="week-day {{item.selected ? 'selected' : ''}} {{item.isToday ? 'today' : ''}}"
      bindtap="onSelectDay"
      data-date="{{item.date}}"
    >
      <text class="week-day-name">{{item.shortName}}</text>
      <view class="week-day-num-wrap">
        <text class="week-day-num">{{item.day}}</text>
      </view>
    </view>
  </view>

  <!-- 空态 -->
  <view wx:if="{{dayItems.length === 0}}" class="empty-state">
    <t-icon name="calendar" size="96rpx" color="#c4c4c9" />
    <text class="empty-title">今日暂无用药计划</text>
    <text class="empty-desc">在「药品管理」中添加药品，开始健康管理</text>
  </view>

  <!-- 药品列表（按时间顺序平铺） -->
  <view class="med-list" wx:if="{{dayItems.length > 0}}">
    <view
      wx:for="{{dayItems}}"
      wx:key="id"
      class="med-card {{item.taken ? 'taken' : ''}} {{item.urgent ? 'urgent' : ''}}"
    >
      <view class="med-card-body">
        <view class="med-info">
          <text class="med-time">{{item.timeLabel}}</text>
          <text class="med-name {{item.taken ? 'name-taken' : ''}}">{{item.name}}</text>
          <text class="med-desc">{{item.dosageDesc}}</text>
          <view class="med-usage">
            <text class="med-usage-label">服用进度</text>
            <view class="med-progress-track">
              <view
                class="med-progress-fill"
                style="width: {{item.usagePercent}}%; background-color: {{item.taken ? '#006e28' : item.usagePercent < 20 ? '#e53935' : item.color || '#0058bc'}};"
              />
            </view>
            <text class="med-usage-pct">{{item.usagePercent}}%</text>
          </view>
        </view>

        <!-- 打卡操作 -->
        <view
          class="med-action"
          catchtap="onCheckIn"
          data-id="{{item.id}}"
        >
          <block wx:if="{{item.taken}}">
            <view class="action-btn action-done">
              <text class="action-btn-text">已服</text>
            </view>
          </block>
          <block wx:elif="{{item.future}}">
            <view class="action-btn action-pending">
              <text class="action-btn-text">待办</text>
            </view>
          </block>
          <block wx:else>
            <view class="action-btn action-checkin">
              <text class="action-btn-text">{{isPastSelectedDay ? '补录' : '打卡'}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>
</view>

/* pages/settings/about.wxss */

.container {
  padding: 32rpx;
  background-color: var(--surface);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0 48rpx;
  gap: 16rpx;
}

.app-icon {
  width: 128rpx;
  height: 128rpx;
  background-color: #e3f2fd;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--on_surface);
}

.app-version {
  font-size: 26rpx;
  color: var(--on_surface_variant);
}

.info-card {
  background-color: var(--surface-container-lowest);
  border-radius: 20rpx;
  padding: 8rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-primary);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--surface-container);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: var(--on_surface);
}

.info-value {
  font-size: 28rpx;
  color: var(--on_surface_variant);
}

.desc-card {
  background-color: var(--surface-container-lowest);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-primary);
}

.desc-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--on_surface);
  margin-bottom: 16rpx;
}

.desc-text {
  display: block;
  font-size: 26rpx;
  color: var(--on_surface_variant);
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.desc-text:last-child {
  margin-bottom: 0;
}

.footer {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  padding: 48rpx 0;
  gap: 8rpx;
}

.copyright {
  font-size: 22rpx;
  color: var(--on_surface_variant);
}

.license {
  font-size: 20rpx;
  color: var(--surface-variant);
}

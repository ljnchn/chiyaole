<!--pages/settings/about.wxml-->
<view class="container">
  <view class="logo-section">
    <view class="app-icon">
      <t-icon name="heart-filled" size="64rpx" color="#0058bc" />
    </view>
    <text class="app-name">吃药了</text>
    <text class="app-version">{{version}}</text>
  </view>

  <view class="info-card">
    <view class="info-row">
      <text class="info-label">版本号</text>
      <text class="info-value">{{version}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">构建日期</text>
      <text class="info-value">{{buildDate}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">基础库版本</text>
      <text class="info-value">3.0.0</text>
    </view>
  </view>

  <view class="desc-card">
    <text class="desc-title">关于吃药了</text>
    <text class="desc-text">「吃药了」是一款温馨优雅的用药管理小程序，采用"生活的圣殿"设计理念，将医疗功能与高端杂志美学结合，让健康管理充满温度。</text>
    <text class="desc-text">我们致力于帮助您养成规律的服药习惯，守护您和家人的健康。</text>
  </view>

  <view class="footer">
    <text class="copyright">© 2026 吃药了 · 用心守护每一天</text>
    <text class="license">Apache License 2.0</text>
  </view>
</view>

/* pages/settings/reminder.wxss */

.container {
  padding: 32rpx;
  background-color: var(--surface);
  min-height: 100vh;
}

.settings-card {
  background-color: var(--surface-container-lowest);
  border-radius: 20rpx;
  padding: 8rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-primary);
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--surface-container);
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.setting-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--on_surface);
}

.setting-desc {
  font-size: 24rpx;
  color: var(--on_surface_variant);
}

.picker-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.picker-display text {
  font-size: 28rpx;
  color: var(--on_surface_variant);
}

.tips-card {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background-color: #e3f2fd;
  border-radius: 16rpx;
  align-items: flex-start;
}

.tips-text {
  flex: 1;
  font-size: 24rpx;
  color: #0058bc;
  line-height: 1.6;
}

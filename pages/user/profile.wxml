<!-- pages/user/profile.wxml -->
<view class="container">
  <form class="profile-form" bindsubmit="onSubmitSave">
    <view class="form-section">
      <text class="section-title">基本信息</text>

      <!-- 点击左侧头像即可选择；昵称在右侧 -->
      <view class="profile-top-row">
        <button
          class="avatar-btn"
          open-type="chooseAvatar"
          bindchooseavatar="onChooseAvatar"
          hover-class="avatar-btn-hover"
        >
          <image
            wx:if="{{avatarUrl}}"
            class="avatar-preview"
            src="{{avatarUrl}}"
            mode="aspectFill"
            lazy-load
            binderror="onAvatarImageError"
          />
          <view wx:else class="avatar-placeholder">
            <text class="avatar-placeholder-text">{{avatarLetter}}</text>
          </view>
        </button>
        <view class="nickname-field">
          <text class="form-label">昵称</text>
          <input
            class="nickname-input"
            type="nickname"
            name="nickName"
            placeholder="请输入昵称"
            value="{{nickName}}"
            bindinput="onNickNameInput"
            bindblur="onNickNameBlur"
          />
        </view>
      </view>

      <view class="profile-hints">
        <text class="profile-hint">点击左侧头像，使用微信能力从相册或使用官方头像。</text>
        <text class="profile-hint">在右侧填写昵称；无头像时将显示昵称首字，修改后请点「保存」。</text>
      </view>
    </view>

    <!-- 紧急联系人（暂隐藏）
    <view class="form-section">
      <text class="section-title">紧急联系人</text>
      <view class="form-item">
        <text class="form-label">姓名</text>
        <t-input
          placeholder="联系人姓名"
          value="{{emergencyName}}"
          bindchange="onEmergencyNameInput"
          borderless
        />
      </view>
      <view class="form-item">
        <text class="form-label">电话</text>
        <t-input
          placeholder="联系人电话"
          value="{{emergencyPhone}}"
          bindchange="onEmergencyPhoneInput"
          type="number"
          borderless
        />
      </view>
    </view>
    -->

    <view class="save-section">
      <button class="btn-save" formType="submit">保存</button>
    </view>
  </form>
</view>

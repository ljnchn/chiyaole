/* pages/user/profile.wxss */

.container {
  padding: 32rpx;
  padding-bottom: 200rpx;
  background-color: var(--surface);
  min-height: 100vh;
}

.form-section {
  background-color: var(--surface-container-lowest);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-primary);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--on_surface);
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: var(--on_surface_variant);
  margin-bottom: 12rpx;
}

.save-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: var(--surface);
}

.profile-form {
  width: 100%;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 9999rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 88, 188, 0.2);
}

.btn-save:active {
  transform: scale(0.98);
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-preview {
  width: 96rpx;
  height: 96rpx;
  border-radius: 9999rpx;
  background-color: rgba(0, 88, 188, 0.06);
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 9999rpx;
  background-color: rgba(0, 88, 188, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.btn-choose-avatar {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 9999rpx;
  background-color: var(--surface-container-lowest);
  color: var(--on_surface_variant);
  border: none;
  box-shadow: var(--shadow-primary);
}

.btn-choose-avatar:active {
  transform: scale(0.98);
}

.nickname-input {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  background-color: var(--surface-container-lowest);
  padding: 0 24rpx;
  box-shadow: var(--shadow-primary);
  box-sizing: border-box;
  color: var(--on_surface);
}

/* pages/user/profile.wxss */

.container {
  padding: 32rpx;
  padding-bottom: 200rpx;
  background-color: var(--surface);
  min-height: 100vh;
}

.form-section {
  background-color: var(--surface-container-lowest);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-primary);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--on_surface);
  margin-bottom: 24rpx;
}

.profile-hints {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 88, 188, 0.08);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-hint {
  display: block;
  font-size: 22rpx;
  color: var(--on_surface_variant);
  line-height: 1.55;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: var(--on_surface_variant);
  margin-bottom: 12rpx;
}

.save-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: var(--surface);
}

.profile-form {
  width: 100%;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 9999rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 88, 188, 0.2);
}

.btn-save:active {
  transform: scale(0.98);
}

/* 头像 + 昵称同一行 */
.profile-top-row {
  display: flex;
  align-items: flex-end;
  gap: 28rpx;
}

.avatar-btn {
  flex-shrink: 0;
  width: 128rpx;
  height: 128rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  line-height: 1;
  border-radius: 9999rpx;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-btn-hover {
  opacity: 0.88;
}

.avatar-preview {
  width: 128rpx;
  height: 128rpx;
  border-radius: 9999rpx;
  background-color: rgba(0, 88, 188, 0.08);
  display: block;
}

.avatar-placeholder {
  width: 128rpx;
  height: 128rpx;
  border-radius: 9999rpx;
  background: linear-gradient(145deg, rgba(0, 88, 188, 0.12) 0%, rgba(0, 88, 188, 0.06) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.avatar-placeholder-text {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1;
}

.nickname-field {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.nickname-field .form-label {
  margin-bottom: 12rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  background-color: var(--surface);
  padding: 0 24rpx;
  box-shadow: var(--shadow-primary);
  box-sizing: border-box;
  color: var(--on_surface);
}

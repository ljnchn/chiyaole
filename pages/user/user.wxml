<!--pages/user/user.wxml-->
<view class="container">
  <!-- User Card -->
  <view class="user-card" bindtap="onEditProfile">
    <view class="avatar">
      <image
        wx:if="{{userInfo.avatarUrl}}"
        src="{{userInfo.avatarUrl}}"
        mode="aspectFill"
        lazy-load
        binderror="onAvatarError"
      />
      <view wx:else class="avatar-placeholder">
        <text>{{userInfo.nickName[0]}}</text>
      </view>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName}}</text>
    </view>
    <t-icon name="chevron-right" size="40rpx" color="#c4c4c9" />
  </view>

  <!-- 登录失败时提供手动重试入口 -->
  <view wx:if="{{loginError}}" class="sync-card">
    <t-icon name="error-circle" size="36rpx" color="#e53935" />
    <text class="sync-text">{{loginError}}</text>
    <button size="mini" class="btn-retry-login" bindtap="onRetryLogin" loading="{{isRetryingLogin}}">
      重新登录
    </button>
  </view>

  <!-- 同步微信信息 -->
  <view wx:if="{{!userInfo.avatarUrl}}" class="sync-card" bindtap="onSyncWxProfile">
    <t-icon name="logo-wechat" size="36rpx" color="#07c160" />
    <text class="sync-text">同步微信头像和昵称</text>
    <t-icon name="chevron-right" size="28rpx" color="#c4c4c9" />
  </view>

  <!-- Settings List -->
  <view class="settings-group">
    <view
      wx:for="{{settings}}"
      wx:key="id"
      class="setting-item"
      bindtap="onSettingTap"
      data-id="{{item.id}}"
    >
      <view class="setting-icon" style="background-color: {{item.iconColor}}20;">
        <t-icon name="{{item.icon}}" size="40rpx" color="{{item.iconColor}}" />
      </view>
      <view class="setting-content">
        <text class="setting-title">{{item.title}}</text>
        <text class="setting-desc">{{item.desc}}</text>
      </view>
      <view class="setting-extra">
        <text wx:if="{{item.value}}" class="setting-value">{{item.value}}</text>
        <t-icon name="chevron-right" size="32rpx" color="#c4c4c9" />
      </view>
    </view>
  </view>

  <!-- Logout Button -->
  <!-- 先隐藏退出登录入口：避免误操作；后续需要再恢复 wx:if -->
  <view class="logout-section" wx:if="{{false}}">
    <button class="btn-logout" bindtap="onLogout">
      <t-icon name="logout" size="34rpx" color="#e53935" />
      <text class="btn-logout-text">退出登录</text>
    </button>
  </view>
</view>
/* pages/record/record.wxss */

.container {
  padding: 24rpx 32rpx;
  padding-bottom: 200rpx;
  background-color: var(--surface);
  min-height: 100vh;
}

/* ========== 顶部栏 ========== */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.top-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.top-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.top-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-btn {
  padding: 8rpx;
}

.icon-btn:active {
  opacity: 0.6;
}

/* ========== 日历卡片 ========== */
.calendar-card {
  background-color: var(--surface-container-lowest);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 36rpx;
  box-shadow: var(--shadow-primary);
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.month-year {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--on_surface);
}

.nav-arrows {
  display: flex;
  gap: 24rpx;
}

.arrow-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.arrow-btn:active {
  background-color: var(--surface-container);
}

/* 星期头 */
.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 16rpx;
}

.week-header text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--on_surface_variant);
  text-align: center;
}

/* 日历格子 */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  row-gap: 8rpx;
}

.cal-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  position: relative;
  min-height: 80rpx;
}

.cal-day-num {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--on_surface);
}

.cal-day.other-month .cal-day-num {
  color: var(--surface-variant);
}

.cal-day.selected {
  position: relative;
}

.cal-day.selected .cal-day-num {
  color: #ffffff;
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  background-color: var(--primary);
  border-radius: 50%;
}

/* 日历状态圆点 */
.cal-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-top: 4rpx;
}

.cal-dot.taken {
  background-color: #006e28;
}

.cal-dot.missed {
  background-color: #e88b8b;
}

.cal-dot.partial {
  background-color: #f59e0b;
}

.cal-dot.pending {
  background-color: var(--primary);
}

/* 图例 */
.legend {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-dot.taken {
  background-color: #006e28;
}

.legend-dot.missed {
  background-color: #e88b8b;
}

.legend-dot.partial {
  background-color: #f59e0b;
}

.legend-dot.pending {
  background-color: var(--primary);
}

.legend-item text {
  font-size: 24rpx;
  color: var(--on_surface_variant);
}

/* ========== 最近记录 ========== */
.records-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--on_surface);
}

.view-more {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--primary);
}

.view-more:active {
  opacity: 0.6;
}

/* 空态 */
.empty-records {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 16rpx;
}

.empty-records text {
  font-size: 26rpx;
  color: var(--on_surface_variant);
}

/* 记录列表 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 记录卡片 */
.record-card {
  display: flex;
  background-color: var(--surface-container-lowest);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-primary);
}

.record-card:active {
  transform: scale(0.98);
  transition: transform 0.15s ease;
}

/* 左侧色条 */
.record-border {
  width: 8rpx;
  flex-shrink: 0;
}

.record-border.border-green {
  background-color: #006e28;
}

.record-border.border-blue {
  background-color: #0058bc;
}

.record-border.border-red {
  background-color: #e53935;
}

.record-border.border-grey {
  background-color: var(--surface-container);
}

/* 记录主体 */
.record-body {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 20rpx;
}

/* 信息区 */
.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.record-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--on_surface);
  margin-bottom: 6rpx;
}

.record-sub {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.record-sub-text {
  font-size: 24rpx;
  line-height: 1.4;
}

.record-time-detail {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--on_surface_variant);
  line-height: 1.4;
}

/* 右侧时间/操作 */
.record-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
}

.taken-badge {
  background-color: #e3f2fd;
}

.taken-badge text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary);
}

.record-time {
  font-size: 24rpx;
  color: var(--on_surface_variant);
}

.makeup-btn {
  padding: 8rpx 24rpx;
  border-radius: 9999rpx;
  border: 2rpx solid var(--surface-container);
  background-color: var(--surface-container-lowest);
}

.makeup-btn text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--on_surface);
}

.makeup-btn:active {
  background-color: var(--surface-container);
}

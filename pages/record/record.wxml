<!--pages/record/record.wxml-->
<view class="container">
  <!-- 日历卡片 -->
  <view class="calendar-card">
    <view class="calendar-header">
      <text class="month-year">{{currentYear}}年{{currentMonth}}月</text>
      <view class="nav-arrows">
        <view class="arrow-btn" bindtap="onPrevMonth">
          <t-icon name="chevron-left" size="36rpx" color="#1b1b1f" />
        </view>
        <view class="arrow-btn" bindtap="onNextMonth">
          <t-icon name="chevron-right" size="36rpx" color="#1b1b1f" />
        </view>
      </view>
    </view>

    <view class="week-header">
      <text wx:for="{{weekDays}}" wx:key="index">{{item}}</text>
    </view>

    <view class="calendar-grid">
      <view
        wx:for="{{calendarDays}}"
        wx:key="index"
        class="cal-day {{item.currentMonth ? '' : 'other-month'}} {{item.selected ? 'selected' : ''}}"
        bindtap="onSelectDate"
        data-day="{{item}}"
      >
        <text class="cal-day-num">{{item.day}}</text>
        <view wx:if="{{item.status === 'taken'}}" class="cal-dot taken"></view>
        <view wx:elif="{{item.status === 'partial'}}" class="cal-dot partial"></view>
        <view wx:elif="{{item.status === 'missed'}}" class="cal-dot missed"></view>
        <view wx:elif="{{item.status === 'pending'}}" class="cal-dot pending"></view>
      </view>
    </view>

    <!-- 图例 -->
    <view class="legend">
      <view class="legend-item">
        <view class="legend-dot taken"></view>
        <text>已服药</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot partial"></view>
        <text>部分已服</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot missed"></view>
        <text>漏服</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot pending"></view>
        <text>待服</text>
      </view>
    </view>
  </view>

  <!-- 最近记录（多日内打卡，非仅当日） -->
  <view class="records-section">
    <view class="section-header">
      <text class="section-title">最近记录</text>
    </view>

    <!-- 空态 -->
    <view wx:if="{{records.length === 0}}" class="empty-records">
      <t-icon name="calendar" size="80rpx" color="#c4c4c9" />
      <text>最近暂无打卡记录</text>
    </view>

    <!-- 记录列表 -->
    <view wx:else class="record-list">
      <view
        wx:for="{{records}}"
        wx:key="id"
        class="record-card"
      >
        <!-- 左侧色条 -->
        <view class="record-border {{item.borderClass}}"></view>

        <view class="record-body">
          <view class="record-info">
            <text class="record-name">{{item.name}}</text>
            <view class="record-sub">
              <t-icon
                wx:if="{{item.subIcon}}"
                name="{{item.subIcon}}"
                size="24rpx"
                color="{{item.subColor}}"
              />
              <text class="record-sub-text" style="color: {{item.subColor}};">{{item.subText}}</text>
            </view>
            <text wx:if="{{item.timeDetail}}" class="record-time-detail">{{item.timeDetail}}</text>
          </view>

          <!-- 右侧时间/操作 -->
          <view class="record-meta">
            <view wx:if="{{item.status === 'taken' && item.isToday}}" class="status-badge taken-badge">
              <text>{{item.badgeText}}</text>
            </view>
            <text wx:elif="{{item.timeLabel}}" class="record-time">{{item.timeLabel}}</text>

            <view
              wx:if="{{item.status === 'missed'}}"
              class="makeup-btn"
              catchtap="onMakeup"
              data-id="{{item.id}}"
            >
              <text>补录</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

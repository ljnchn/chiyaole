<!--pages/medication/list.wxml-->
<view class="container">
  <!-- 统计卡片 -->
  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-label">药品总数</text>
      <view class="stat-value">
        <text class="stat-number">{{stats.total}}</text>
        <text class="stat-unit">项</text>
      </view>
    </view>
    <view class="stat-card warning">
      <text class="stat-label warning-label">库存告急</text>
      <view class="stat-value">
        <text class="stat-number warning-number">{{stats.lowStock}}</text>
        <text class="stat-unit">项</text>
      </view>
    </view>
  </view>
  <!-- 板块标题 -->
  <view class="section-header">
    <text class="section-title">我的药箱</text>
  </view>

  <!-- 空态 -->
  <view wx:if="{{filteredList.length === 0}}" class="empty-state">
    <t-icon name="shop" size="96rpx" color="#c4c4c9" />
    <text class="empty-title">{{medications.length === 0 ? '还没有添加药品' : '没有匹配的药品'}}</text>
    <text class="empty-desc">{{medications.length === 0 ? '请通过添加药品入口录入您的药品' : '试试其他搜索词或筛选条件'}}</text>
    <view class="bottom-add-wrap">
      <view class="bottom-add-btn" bindtap="onAddMedication">
        <t-icon name="add" size="32rpx" color="#ffffff" />
        <text>添加药品</text>
      </view>
    </view>
  </view>

  <!-- 药品列表 -->
  <view wx:else class="list-wrap">
    <view class="medication-list">
      <view
        wx:for="{{filteredList}}"
        wx:key="id"
        class="med-card"
        bindtap="onMedicationTap"
        data-id="{{item.id}}"
      >
        <!-- 药品名 + 库存告急徽章 -->
        <view class="med-header">
          <text class="med-name">{{item.name}}</text>
          <view wx:if="{{item.lowStock}}" class="low-stock-badge">
            <text>库存告急</text>
          </view>
        </view>

        <!-- 规格 -->
        <text class="med-spec">{{item.specification}}</text>

        <!-- 库存进度 -->
        <view class="stock-row">
          <view class="stock-text-wrap">
            <text class="stock-label {{item.lowStock ? 'stock-warn' : ''}}">剩余 </text>
            <text class="stock-value {{item.lowStock ? 'stock-warn' : ''}}">{{item.remaining}} / {{item.total}}</text>
            <text class="stock-label {{item.lowStock ? 'stock-warn' : ''}}"> {{item.unit}}</text>
          </view>
          <text class="stock-pct">{{item.stockPercent}}%</text>
        </view>

        <!-- 进度条 -->
        <view class="stock-progress">
          <view
            class="progress-fill"
            style="width: {{item.stockPercent}}%; background-color: {{item.lowStock ? '#e53935' : '#0058bc'}};"
          />
        </view>
      </view>
    </view>

    <view class="bottom-add-wrap">
      <view class="bottom-add-btn" bindtap="onAddMedication">
        <t-icon name="add" size="32rpx" color="#ffffff" />
        <text>添加药品</text>
      </view>
    </view>
  </view>
</view>

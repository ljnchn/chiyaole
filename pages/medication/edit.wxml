<!--pages/medication/edit.wxml-->
<view class="page">
  <!-- 自定义导航栏（与新增保持一致） -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-cancel" bindtap="onCancel">取消</text>
      <text class="nav-title">编辑药品</text>
      <view class="nav-right-space"></view>
    </view>
  </view>
  <view style="height: {{navBarHeight}}px;"></view>

  <scroll-view scroll-y class="form-scroll" style="height: calc(100vh - {{navBarHeight}}px - 140rpx);">
    <view class="container">

      <!-- 药品名称 -->
      <view class="form-card">
        <text class="card-label">药品名称</text>
        <view class="input-box">
          <view class="input-icon">
            <t-icon name="flag" size="36rpx" color="#8e8e93" />
          </view>
          <input
            class="input-field"
            placeholder="例如：阿莫西林"
            placeholder-class="input-placeholder"
            value="{{name}}"
            bindinput="onNameInput"
          />
        </view>
      </view>

      <!-- 开始时间、服用剂量、用药间隔、服用方式 -->
      <view class="form-card">
        <!-- 开始时间 -->
        <text class="card-label">开始时间</text>
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="input-box small picker">
            <text class="{{startDate ? 'input-value' : 'input-placeholder'}}">{{startDate || '请选择开始日期'}}</text>
            <t-icon name="chevron-right" size="32rpx" color="#8e8e93" />
          </view>
        </picker>

        <view class="form-row" style="margin-top: 28rpx;">
          <view class="form-col">
            <text class="card-label">服用剂量</text>
            <view class="dosage-inline">
              <view class="input-box small dosage-inline-input">
                <input
                  class="input-field"
                  type="digit"
                  placeholder="如 1、10"
                  placeholder-class="input-placeholder"
                  value="{{dosageInput}}"
                  bindinput="onDosageInput"
                />
              </view>
              <picker mode="selector" range="{{dosageUnitLabels}}" value="{{dosageUnitIndex}}" bindchange="onDosageUnitChange">
                <view class="input-box small picker dosage-inline-unit">
                  <text class="{{dosageUnit ? 'input-value' : 'input-placeholder'}}">{{dosageUnit || '单位'}}</text>
                  <t-icon name="chevron-down" size="32rpx" color="#8e8e93" />
                </view>
              </picker>
            </view>
          </view>
          <view class="form-col">
            <text class="card-label">用药间隔</text>
            <view class="input-box small picker" bindtap="onShowIntervalPicker">
              <text class="input-value">{{intervalLabelText}}</text>
              <t-icon name="chevron-down" size="32rpx" color="#8e8e93" />
            </view>
          </view>
        </view>
        <text class="card-hint">决定哪些日期需要服药；当天吃几顿由下方用药时间决定</text>

        <!-- 服用方式 -->
        <text class="card-label" style="margin-top: 28rpx;">服用方式</text>
        <view class="chip-row">
          <view
            wx:for="{{foodOptions}}"
            wx:key="value"
            class="chip {{withFood === item.value ? 'active' : ''}}"
            bindtap="onSelectFood"
            data-value="{{item.value}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 用药时间设置 -->
      <view class="form-card">
        <view class="card-header">
          <view class="card-header-left">
            <t-icon name="time-filled" size="36rpx" color="#0058bc" />
            <text class="card-header-title">用药时间设置</text>
          </view>
          <view class="card-header-action" bindtap="onAddTime">
            <t-icon name="add-circle" size="32rpx" color="#0058bc" />
            <text class="action-text">添加时间点</text>
          </view>
        </view>

        <view class="time-chips" wx:if="{{times.length > 0}}">
          <view wx:for="{{times}}" wx:key="index" class="time-chip">
            <text>{{item}}</text>
            <view class="chip-remove" catchtap="onRemoveTime" data-index="{{index}}">
              <t-icon name="close" size="24rpx" color="#8e8e93" />
            </view>
          </view>
        </view>
        <view wx:else class="time-empty">
          <text class="time-empty-text">点击右上角添加服药时间</text>
        </view>
      </view>

      <!-- 库存管理 -->
      <view class="form-card">
        <view class="card-header">
          <view class="card-header-left">
            <t-icon name="shop" size="36rpx" color="#006e28" />
            <text class="card-header-title">库存管理</text>
          </view>
        </view>

        <!-- 总量 + 剩余 -->
        <view class="form-row" style="margin-top: 24rpx;">
          <view class="form-col">
            <text class="card-label">药物总量</text>
            <view class="stock-input-wrap">
              <t-stepper
                class="stock-stepper"
                style="width: 100%;"
                value="{{total}}"
                min="{{0}}"
                step="{{1}}"
                theme="filled"
                size="small"
                bindchange="onTotalStepperChange"
              />
            </view>
          </view>
          <view class="form-col">
            <text class="card-label">当前剩余</text>
            <view class="stock-input-wrap">
              <t-stepper
                class="stock-stepper"
                style="width: 100%;"
                value="{{remaining}}"
                min="{{0}}"
                step="{{1}}"
                theme="filled"
                size="small"
                bindchange="onRemainingStepperChange"
              />
            </view>
          </view>
        </view>

        <!-- 库存预警 -->
        <view class="alert-section">
          <view class="alert-header">
            <view class="alert-left">
              <text class="alert-title">库存预警</text>
              <text class="alert-desc">库存低于阈值时发送通知</text>
            </view>
            <switch checked="{{lowStockEnabled}}" bindchange="onLowStockEnabledChange" color="#006e28" />
          </view>

          <view wx:if="{{lowStockEnabled}}" class="slider-section">
            <view class="slider-row">
              <text class="slider-label">当少于</text>
              <t-stepper
                value="{{lowStockThreshold}}"
                min="{{0}}"
                max="{{total || 100}}"
                step="{{1}}"
                theme="filled"
                size="small"
                bindchange="onThresholdStepperChange"
              />
              <text class="slider-suffix">时提醒</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 备注事项 -->
      <view class="form-card">
        <text class="card-label">备注事项</text>
        <view class="textarea-wrap">
          <textarea
            class="remark-textarea"
            placeholder="例如：饭后服用，避免饮酒..."
            placeholder-class="input-placeholder"
            value="{{remark}}"
            bindinput="onRemarkInput"
            maxlength="200"
            auto-height
          />
        </view>
      </view>

      <!-- 底部提示 -->
      <view class="footer-hint">
        <text>设置完成后，我们将按照设定的频率与时间为您准时提醒，请确保系统通知已开启。</text>
      </view>

    </view>
  </scroll-view>

  <!-- 底部保存按钮 -->
  <view class="bottom-action">
    <button class="bottom-save-btn" bindtap="onSave">保存</button>
  </view>
</view>

<!-- 时间选择器 -->
<t-picker
  visible="{{showTimePicker}}"
  title="选择时间"
  cancelBtn="取消"
  confirmBtn="确认"
  value="{{['08', '00']}}"
  bindconfirm="onTimePickerConfirm"
  bindcancel="onTimePickerCancel"
>
  <t-picker-item options="{{timeHourOptions}}" />
  <t-picker-item options="{{timeMinuteOptions}}" />
</t-picker>

<!-- 用药间隔 -->
<t-picker
  visible="{{showIntervalPicker}}"
  title="选择用药间隔"
  cancelBtn="取消"
  confirmBtn="确认"
  value="{{intervalPickerValue}}"
  bindconfirm="onIntervalPickerConfirm"
  bindcancel="onIntervalPickerCancel"
>
  <t-picker-item options="{{intervalOptions}}" />
</t-picker>

/* app.wxss - Global Styles */

/* Design System Tokens - The Serene Healer */
page {
  /* Primary - Medical Precision */
  --primary: #0058bc;
  --primary-container: #0070eb;

  /* Secondary - Organic Growth */
  --secondary: #006e28;
  --secondary-container: #6ffb85;

  /* Surface Hierarchy */
  --surface: #f9f9fe;
  --surface-container: #ededf2;
  --surface-container-lowest: #ffffff;
  --surface-variant: #c4c4c9;

  /* Text Colors */
  --on_surface: #1b1b1f;
  --on_surface_variant: #414755;

  /* Typography - System Chinese Fonts */
  --font-body: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;

  /* Shadows */
  --shadow-primary: 0 8rpx 24rpx rgba(0, 88, 188, 0.08);

  /* Override TDesign tokens */
  --td-brand-color: #0058bc;
  --td-brand-color-light: #0070eb;
  --td-success-color: #006e28;
  --td-bg-color-page: #f9f9fe;
  --td-bg-color-container: #ffffff;
  --td-text-color-primary: #1b1b1f;
  --td-text-color-secondary: #414755;
  --td-border-radius: 12rpx;

  /* Page background */
  background-color: var(--surface);
  font-family: var(--font-body);
  color: var(--on_surface);
}

/* Reset - WXSS 不支持 * 选择器 */
view, text, image, navigator, input, button, scroll-view, swiper {
  box-sizing: border-box;
}


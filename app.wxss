/* app.wxss - Global Styles */

/* Design System Tokens - The Serene Healer */
page {
  /* Primary - Medical Precision */
  --primary: #0058bc;
  --primary-container: #0070eb;

  /* Secondary - Organic Growth */
  --secondary: #006e28;
  --secondary-container: #6ffb85;
  --secondary-fixed: #e8f5e9;

  /* Tertiary - Insights */
  --tertiary: #4c4aca;

  /* Surface Hierarchy */
  --surface: #f9f9fe;
  --surface-dim: #e0e0e5;
  --surface-container: #ededf2;
  --surface-container-high: #e2e2e7;
  --surface-container-low: #f3f3f8;
  --surface-container-lowest: #ffffff;
  --surface-variant: #c4c4c9;

  /* Text Colors */
  --on_surface: #1b1b1f;
  --on_surface_variant: #414755;
  --outline_variant: #c4c4c9;

  /* Typography - System Chinese Fonts */
  --font-display: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  --font-body: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;

  /* Spacing (4px base) */
  --spacing-1: 4rpx;
  --spacing-2: 8rpx;
  --spacing-3: 12rpx;
  --spacing-4: 16rpx;
  --spacing-5: 20rpx;
  --spacing-6: 24rpx;
  --spacing-8: 32rpx;
  --spacing-10: 40rpx;
  --spacing-12: 48rpx;

  /* Border Radius */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-full: 9999rpx;

  /* Shadows */
  --shadow-primary: 0 8rpx 24rpx rgba(0, 88, 188, 0.08);

  /* Override TDesign tokens */
  --td-brand-color: #0058bc;
  --td-brand-color-light: #0070eb;
  --td-success-color: #006e28;
  --td-bg-color-page: #f9f9fe;
  --td-bg-color-container: #ffffff;
  --td-text-color-primary: #1b1b1f;
  --td-text-color-secondary: #414755;
  --td-border-radius: 12rpx;

  /* Page background */
  background-color: var(--surface);
  font-family: var(--font-body);
  color: var(--on_surface);
}

/* Reset - WXSS 不支持 * 选择器 */
view, text, image, navigator, input, button, scroll-view, swiper {
  box-sizing: border-box;
}

/* Typography Classes */
.text-display {
  font-family: var(--font-display);
  font-weight: 600;
}

.text-headline-lg {
  font-family: var(--font-display);
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1.2;
}

.text-headline-md {
  font-family: var(--font-display);
  font-size: 48rpx;
  font-weight: 600;
  line-height: 1.3;
}

.text-body-md {
  font-family: var(--font-body);
  font-size: 28rpx;
  line-height: 1.5;
}

.text-body-sm {
  font-family: var(--font-body);
  font-size: 24rpx;
  line-height: 1.5;
}

.text-label-md {
  font-family: var(--font-body);
  font-size: 24rpx;
  color: var(--on_surface_variant);
}

/* Surface Utilities */
.bg-surface {
  background-color: var(--surface);
}

.bg-surface-container {
  background-color: var(--surface-container);
}

.bg-surface-container-high {
  background-color: var(--surface-container-high);
}

.bg-surface-container-low {
  background-color: var(--surface-container-low);
}

.bg-surface-container-lowest {
  background-color: var(--surface-container-lowest);
}

/* Spacing Utilities */
.p-4 {
  padding: var(--spacing-4);
}

.p-5 {
  padding: var(--spacing-5);
}

.px-4 {
  padding-left: var(--spacing-4);
  padding-right: var(--spacing-4);
}

.py-4 {
  padding-top: var(--spacing-4);
  padding-bottom: var(--spacing-4);
}

.gap-4 {
  gap: var(--spacing-4);
}

.gap-8 {
  gap: var(--spacing-8);
}

/* Radius Utilities */
.rounded-sm {
  border-radius: var(--radius-sm);
}

.rounded-md {
  border-radius: var(--radius-md);
}

.rounded-lg {
  border-radius: var(--radius-lg);
}

.rounded-full {
  border-radius: var(--radius-full);
}

/* Card Pattern - No borders */
.card {
  background-color: var(--surface-container-lowest);
  border-radius: var(--radius-md);
  padding: var(--spacing-5);
}

.card-elevated {
  background-color: var(--surface-container-lowest);
  border-radius: var(--radius-md);
  padding: var(--spacing-5);
  box-shadow: var(--shadow-primary);
}

/* Signature Check-in Button */
.btn-checkin {
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-container) 100%);
  color: #ffffff;
  border-radius: var(--radius-full);
  padding: var(--spacing-4) var(--spacing-8);
  font-family: var(--font-display);
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 110, 40, 0.15);
  transition: transform 0.1s ease;
}

.btn-checkin:active {
  transform: scale(0.98);
}

/* CTA Button with Primary Gradient */
.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
  color: #ffffff;
  border-radius: var(--radius-full);
  border: none;
}

/* Ghost Border (if absolutely needed) */
.ghost-border {
  border: 2rpx solid rgba(196, 196, 201, 0.15);
}

/* Glassmorphism */
.glass {
  background-color: rgba(249, 249, 254, 0.7);
  backdrop-filter: blur(20rpx);
}

/* Section Spacing */
.section {
  margin-bottom: var(--spacing-8);
}

.section-lg {
  margin-bottom: var(--spacing-10);
}

/* Safe Area */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
